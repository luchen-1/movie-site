{
  "name": "cinepulse",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A movie rating site with Douban now-playing sync, local reviews, and scheduled updates.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync": "tsx src/scripts/run-sync.ts",
    "check": "npm run lint && npm run test && npm run build"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.1.2",
    "compression": "^1.8.1",
    "dayjs": "^1.11.13",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "sanitize-html": "^2.17.0",
    "slugify": "^1.6.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.5",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.6.2",
    "@types/sanitize-html": "^2.16.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.38.0",
    "globals": "^16.4.0",
    "playwright": "^1.52.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^3.2.4"
  }
}
